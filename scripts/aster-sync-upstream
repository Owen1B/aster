#!/usr/bin/env bash
set -euo pipefail

DEFAULT_UPSTREAM_REMOTE="upstream"
DEFAULT_UPSTREAM_URL="https://github.com/openai/codex.git"
TRACKING_FILE="${ASTER_TRACKING_FILE:-ASTER_UPSTREAM_TRACKING.env}"

UPSTREAM_REMOTE="${ASTER_UPSTREAM_REMOTE:-${DEFAULT_UPSTREAM_REMOTE}}"
UPSTREAM_URL="${ASTER_UPSTREAM_URL:-${DEFAULT_UPSTREAM_URL}}"
TARGET_TAG="${ASTER_UPSTREAM_TAG:-latest-stable}"
BASE_TAG=""
SOURCE_REF="HEAD"
MODE="fetch-only"
PRINT_TAG_ONLY=0
TARGET_BRANCH=""

if [[ -f "${TRACKING_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${TRACKING_FILE}"
  UPSTREAM_REMOTE="${ASTER_UPSTREAM_REMOTE:-${UPSTREAM_REMOTE}}"
  UPSTREAM_URL="${ASTER_UPSTREAM_URL:-${UPSTREAM_URL}}"
  BASE_TAG="${ASTER_LAST_SYNCED_UPSTREAM_TAG:-${BASE_TAG}}"
fi

BASE_TAG="${BASE_TAG:-rust-v0.122.0}"

usage() {
  cat <<'USAGE'
Usage: scripts/aster-sync-upstream [options]

Fetch and optionally prepare a patch-stack rebase of Aster onto an official
openai/codex Rust release tag.

Safe commands:
  scripts/aster-sync-upstream --target latest-stable --fetch-only
  scripts/aster-sync-upstream --target latest-stable --print-tag

Prepare an update branch after main has been migrated to upstream-history mode:
  scripts/aster-sync-upstream \
    --target rust-v0.123.0 \
    --base-tag rust-v0.122.0 \
    --source-ref main \
    --create-branch

Options:
  --target TAG            Upstream tag, latest-stable, or latest-prerelease.
  --base-tag TAG          Previous upstream tag that current Aster commits sit on.
                          Defaults to ASTER_LAST_SYNCED_UPSTREAM_TAG.
  --source-ref REF        Aster ref containing commits to rebase. Default: HEAD.
  --branch NAME           Branch to create. Default: zhw_dev/aster-sync-X.Y.Z.
  --fetch-only            Fetch target upstream tag and print status. Default.
  --create-branch         Create a branch and rebase Aster commits onto target tag.
  --print-tag             Print the resolved upstream tag only.
  --upstream-remote NAME  Git remote name. Default: upstream.
  --upstream-url URL      Official upstream URL. Default: openai/codex.
  -h, --help              Show this help.

Model:
  This script assumes Aster is a normal patch stack on top of upstream history:

      upstream-rust-v0.122.0 --- Aster commits     (current main)
      upstream-rust-v0.123.0 --- Aster commits     (new sync branch)

  It intentionally avoids snapshot-tree replacement. If rebase conflicts occur,
  resolve them normally with git, then continue the rebase.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      TARGET_TAG="$2"
      shift 2
      ;;
    --base-tag)
      BASE_TAG="$2"
      shift 2
      ;;
    --source-ref)
      SOURCE_REF="$2"
      shift 2
      ;;
    --branch)
      TARGET_BRANCH="$2"
      shift 2
      ;;
    --fetch-only)
      MODE="fetch-only"
      shift
      ;;
    --create-branch)
      MODE="create-branch"
      shift
      ;;
    --print-tag)
      PRINT_TAG_ONLY=1
      shift
      ;;
    --upstream-remote)
      UPSTREAM_REMOTE="$2"
      shift 2
      ;;
    --upstream-url)
      UPSTREAM_URL="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

valid_tag_pattern='^rust-v[0-9]+\.[0-9]+\.[0-9]+(-alpha\.[0-9]+)?$'
stable_tag_pattern='^rust-v[0-9]+\.[0-9]+\.[0-9]+$'

latest_tag() {
  local pattern="$1"
  git ls-remote --tags --refs "${UPSTREAM_URL}" 'rust-v*' \
    | awk '{print $2}' \
    | sed 's#refs/tags/##' \
    | grep -E "${pattern}" \
    | sort -V \
    | tail -1
}

resolve_target_tag() {
  case "${TARGET_TAG}" in
    latest-stable)
      latest_tag "${stable_tag_pattern}"
      ;;
    latest-prerelease|latest-any)
      latest_tag "${valid_tag_pattern}"
      ;;
    *)
      if [[ ! "${TARGET_TAG}" =~ ${valid_tag_pattern} ]]; then
        echo "Invalid upstream tag: ${TARGET_TAG}" >&2
        exit 2
      fi
      printf '%s\n' "${TARGET_TAG}"
      ;;
  esac
}

ensure_upstream_remote() {
  if git remote get-url "${UPSTREAM_REMOTE}" >/dev/null 2>&1; then
    return
  fi
  git remote add "${UPSTREAM_REMOTE}" "${UPSTREAM_URL}"
}

fetch_tag_alias() {
  local tag="$1"
  ensure_upstream_remote
  git fetch --no-tags "${UPSTREAM_REMOTE}" "+refs/tags/${tag}:refs/tags/upstream-${tag}"
}

require_clean_worktree() {
  if [[ -n "$(git status --porcelain)" ]]; then
    echo "Refusing to create a sync branch because the worktree is not clean." >&2
    echo "Commit/stash your changes first, then rerun this command." >&2
    exit 1
  fi
}

write_tracking_file() {
  local tag="$1"
  local version="${tag#rust-v}"
  cat > "${TRACKING_FILE}" <<EOF_TRACKING
# Aster upstream tracking state.
# Update this file as part of each successful upstream sync PR.
ASTER_UPSTREAM_REMOTE=${UPSTREAM_REMOTE}
ASTER_UPSTREAM_URL=${UPSTREAM_URL}
ASTER_LAST_SYNCED_UPSTREAM_TAG=${tag}
ASTER_PATCH_BASE_REF=upstream-${tag}
ASTER_RELEASE_TAG_PREFIX=aster-v
ASTER_NEXT_RELEASE_TAG=aster-v${version}
EOF_TRACKING
}

create_rebase_branch() {
  local resolved_tag="$1"
  local version="${resolved_tag#rust-v}"
  local base_ref="upstream-${BASE_TAG}"
  local target_ref="upstream-${resolved_tag}"
  local branch="${TARGET_BRANCH:-zhw_dev/aster-sync-${version}}"

  require_clean_worktree
  fetch_tag_alias "${BASE_TAG}"
  git rev-parse --verify "${base_ref}^{commit}" >/dev/null
  git rev-parse --verify "${target_ref}^{commit}" >/dev/null
  git rev-parse --verify "${SOURCE_REF}^{commit}" >/dev/null

  if git show-ref --verify --quiet "refs/heads/${branch}"; then
    echo "Branch already exists: ${branch}" >&2
    exit 1
  fi

  git switch -c "${branch}" "${SOURCE_REF}"
  git rebase --onto "${target_ref}" "${base_ref}" "${branch}"
  write_tracking_file "${resolved_tag}"
  git add "${TRACKING_FILE}"
  if ! git diff --cached --quiet; then
    git commit -m "Update Aster upstream tracking to ${resolved_tag}"
  fi

  cat <<EOF_STATUS
Aster upstream patch-stack sync
  branch:       ${branch}
  old base:     ${base_ref}
  new base:     ${target_ref}
  source ref:   ${SOURCE_REF}

Created sync branch with Aster commits rebased onto ${resolved_tag}.
EOF_STATUS
}

resolved_tag="$(resolve_target_tag)"
if [[ -z "${resolved_tag}" ]]; then
  echo "Could not resolve upstream tag from ${TARGET_TAG}" >&2
  exit 1
fi

if [[ "${PRINT_TAG_ONLY}" -eq 1 ]]; then
  printf '%s\n' "${resolved_tag}"
  exit 0
fi

fetch_tag_alias "${resolved_tag}"

case "${MODE}" in
  fetch-only)
    cat <<EOF_STATUS
Aster upstream patch-stack tracking
  upstream remote: ${UPSTREAM_REMOTE} (${UPSTREAM_URL})
  target tag:      ${resolved_tag}
  local alias:     upstream-${resolved_tag}
  current base:    upstream-${BASE_TAG}
  source ref:      ${SOURCE_REF}

Fetched upstream tag. No worktree files were changed.
EOF_STATUS
    ;;
  create-branch)
    create_rebase_branch "${resolved_tag}"
    ;;
  *)
    echo "Unknown mode: ${MODE}" >&2
    exit 2
    ;;
esac
